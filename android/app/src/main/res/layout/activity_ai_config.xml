<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI 总结配置"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="配置 AI API 后，可以对没有正文的文章进行智能总结"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="24dp" />

        <!-- API 提供商 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="API 提供商"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerProvider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:entries="@array/ai_providers" />

        <!-- 后端 API 地址 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="后端 API 地址"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editApiUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="http://10.0.2.2:8000"
            android:inputType="textUri"
            android:layout_marginBottom="16dp" />

        <!-- AI API Key -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI API Key"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editApiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="sk-..."
            android:inputType="text"
            android:layout_marginBottom="16dp" />

        <!-- 模型 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI 模型"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editModel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="gpt-3.5-turbo"
            android:inputType="text"
            android:layout_marginBottom="24dp" />

        <!-- 测试按钮 -->
        <Button
            android:id="@+id/btnTestAI"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="测试连接"
            android:layout_marginBottom="8dp" />

        <!-- 保存按钮 -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="保存配置"
            android:backgroundTint="@color/purple_500" />

        <!-- 说明文字 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="提示：\n• OpenAI API Key 可在 https://platform.openai.com 获取\n• Claude API Key 可在 https://console.anthropic.com 获取\n• 模拟器使用 10.0.2.2 访问本机\n• 真机请填写电脑的局域网 IP"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginTop="24dp"
            android:padding="12dp"
            android:background="#F5F5F5" />

    </LinearLayout>

</ScrollView>
