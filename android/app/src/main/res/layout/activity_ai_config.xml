<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ai_config_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ai_config_desc"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="24dp" />

        <!-- API 提供商 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ai_config_provider"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerProvider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:entries="@array/ai_providers" />

        <!-- 后端 API 地址 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ai_config_endpoint"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editApiUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/ai_config_endpoint_hint"
            android:inputType="textUri"
            android:layout_marginBottom="16dp" />

        <!-- AI API Key -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ai_config_api_key"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editApiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/ai_config_api_key_hint"
            android:inputType="text"
            android:layout_marginBottom="16dp" />

        <!-- 模型 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ai_config_model"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editModel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/ai_config_model_hint"
            android:inputType="text"
            android:layout_marginBottom="24dp" />

        <!-- 测试按钮 -->
        <Button
            android:id="@+id/btnTestAI"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ai_config_test"
            android:layout_marginBottom="8dp" />

        <!-- 保存按钮 -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ai_config_save"
            android:backgroundTint="@color/purple_500" />

        <!-- 说明文字 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ai_config_tips"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginTop="24dp"
            android:padding="12dp"
            android:background="#F5F5F5" />

    </LinearLayout>

</ScrollView>
